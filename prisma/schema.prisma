generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  HEAD_OF_MARKETING
  TEAM_LEAD
  COLLABORATOR
  VIEWER
}

enum CampaignStatus {
  DRAFT
  PLANNING
  IN_PROGRESS
  AT_RISK
  ON_HOLD
  COMPLETED
}

enum WorkStatus {
  TODO
  IN_PROGRESS
  IN_REVIEW
  BLOCKED
  DONE
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum PerformancePlatform {
  META
  GOOGLE
  TIKTOK
}

model User {
  id                 String        @id @default(cuid())
  name               String
  email              String        @unique
  passwordHash       String?
  title              String
  role               Role
  teamId             String?
  team               Team?         @relation(fields: [teamId], references: [id], onDelete: SetNull)
  ownedCampaigns     Campaign[]    @relation("CampaignOwner")
  ownedUnits         UnitOfWork[]  @relation("UnitOwner")
  ownedDeliverables  Deliverable[] @relation("DeliverableOwner")
  assignedTasks      Task[]        @relation("TaskAssignee")
  comments           Comment[]
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
}

model Team {
  id            String        @id @default(cuid())
  name          String
  slug          String        @unique
  description   String?
  users         User[]
  unitsOfWork   UnitOfWork[]
  deliverables  Deliverable[]
  tasks         Task[]
  campaigns     Campaign[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model Company {
  id          String      @id @default(cuid())
  name        String
  slug        String      @unique
  description String?
  products    Product[]
  campaigns   Campaign[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model Product {
  id          String      @id @default(cuid())
  companyId   String
  company     Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name        String
  slug        String
  description String?
  campaigns   Campaign[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@unique([companyId, slug])
}

model Campaign {
  id            String          @id @default(cuid())
  companyId     String
  productId     String?
  ownerId       String
  name          String
  description   String
  objective     String
  priority      Priority
  status        CampaignStatus
  startDate     DateTime
  endDate       DateTime
  progress      Int             @default(0)
  budgetTotal   Decimal         @db.Decimal(12, 2)
  budgetSpent   Decimal         @db.Decimal(12, 2)
  roi           Decimal         @db.Decimal(8, 2)
  kpiName       String
  kpiValue      String
  company       Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  product       Product?        @relation(fields: [productId], references: [id], onDelete: SetNull)
  owner         User            @relation("CampaignOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  teams         Team[]
  unitsOfWork   UnitOfWork[]
  deliverables  Deliverable[]
  tasks         Task[]
  comments      Comment[]
  performances  Performance[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}

model UnitOfWork {
  id            String        @id @default(cuid())
  campaignId    String
  teamId        String
  ownerId       String?
  name          String
  objective     String
  startDate     DateTime
  endDate       DateTime
  progress      Int           @default(0)
  status        WorkStatus
  campaign      Campaign      @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  team          Team          @relation(fields: [teamId], references: [id], onDelete: Restrict)
  owner         User?         @relation("UnitOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  deliverables  Deliverable[]
  tasks         Task[]
  comments      Comment[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model Deliverable {
  id              String        @id @default(cuid())
  campaignId      String
  unitOfWorkId    String
  ownerId         String?
  teamId          String
  dependencyDeliverableId String?
  title           String
  type            String
  dueDate         DateTime
  status          WorkStatus
  priority        Priority
  reviewRound     Int           @default(1)
  finalUrl        String?
  estimatedHours  Int
  actualHours     Int           @default(0)
  progress        Int           @default(0)
  campaign        Campaign      @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  unitOfWork      UnitOfWork    @relation(fields: [unitOfWorkId], references: [id], onDelete: Cascade)
  owner           User?         @relation("DeliverableOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  team            Team          @relation(fields: [teamId], references: [id], onDelete: Restrict)
  dependencyDeliverable Deliverable? @relation("DeliverableDependency", fields: [dependencyDeliverableId], references: [id], onDelete: SetNull)
  dependentDeliverables Deliverable[] @relation("DeliverableDependency")
  tasks           Task[]
  comments        Comment[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model Task {
  id                String        @id @default(cuid())
  campaignId        String
  deliverableId     String?
  unitOfWorkId      String?
  assigneeId        String?
  teamId            String
  title             String
  description       String
  startDate         DateTime
  dueDate           DateTime
  status            WorkStatus
  priority          Priority
  progress          Int           @default(0)
  dependencyTaskId  String?
  estimatedHours    Int
  actualHours       Int           @default(0)
  isCritical        Boolean       @default(false)
  campaign          Campaign      @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  deliverable       Deliverable?  @relation(fields: [deliverableId], references: [id], onDelete: SetNull)
  unitOfWork        UnitOfWork?   @relation(fields: [unitOfWorkId], references: [id], onDelete: SetNull)
  assignee          User?         @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  team              Team          @relation(fields: [teamId], references: [id], onDelete: Restrict)
  dependencyTask    Task?         @relation("TaskDependency", fields: [dependencyTaskId], references: [id], onDelete: SetNull)
  dependentTasks    Task[]        @relation("TaskDependency")
  comments          Comment[]
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
}

model Comment {
  id             String        @id @default(cuid())
  authorId       String
  campaignId     String?
  unitOfWorkId   String?
  deliverableId  String?
  taskId         String?
  body           String
  author         User          @relation(fields: [authorId], references: [id], onDelete: Cascade)
  campaign       Campaign?     @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  unitOfWork     UnitOfWork?   @relation(fields: [unitOfWorkId], references: [id], onDelete: Cascade)
  deliverable    Deliverable?  @relation(fields: [deliverableId], references: [id], onDelete: Cascade)
  task           Task?         @relation(fields: [taskId], references: [id], onDelete: Cascade)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model Performance {
  id         String              @id @default(cuid())
  campaignId String
  date       DateTime
  platform   PerformancePlatform
  spend      Decimal             @db.Decimal(12, 2)
  revenue    Decimal             @db.Decimal(12, 2)
  purchases  Int
  campaign   Campaign            @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt

  @@index([campaignId, date])
}
