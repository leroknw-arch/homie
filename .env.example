# PostgreSQL database used by Prisma.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/homie"

# Generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-long-random-secret"

# Local application URL. In Vercel, prefer AUTH_TRUST_HOST=true and leave
# AUTH_URL/NEXTAUTH_URL unset unless you are locking auth to one canonical domain.
NEXTAUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"

# Demo-mode helpers for a stable internal walkthrough.
DEMO_PASSWORD="demo1234"
DEMO_REFERENCE_DATE="2026-04-14"
